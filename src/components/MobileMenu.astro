---
// Apple-style fullscreen overlay mobile menu
// Usage: add <MobileMenu /> after </header> in any page
// Requires: a <button id="menuToggle"> in the header
---

<div class="mobile-overlay" id="mobileOverlay">
  <button class="mobile-overlay-close" id="mobileOverlayClose" aria-label="关闭菜单">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="4" x2="16" y2="16"/><line x1="16" y1="4" x2="4" y2="16"/></svg>
  </button>
  <nav class="mobile-overlay-nav">
    <a href="/docs/">文档</a>
    <a href="/themes/">主题</a>
    <a href="/changelog/">更新日志</a>
    <a href="https://github.com/Gridea-Pro/gridea-pro" target="_blank" rel="noopener">GitHub</a>
    <a href="/download/" class="mobile-overlay-download">免费下载</a>
  </nav>
</div>

<style is:global>
/* ── Hamburger button (2-line minimal) ── */
.mobile-menu-btn {
  display: none;
  width: 32px;
  height: 32px;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 6px;
  padding: 4px;
  position: relative;
  z-index: 1100;
  background: none;
  border: none;
  cursor: pointer;
}

.hamburger-line {
  display: block;
  width: 16px;
  height: 1.5px;
  background: #1A1A1A;
  border-radius: 2px;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

/* ── Overlay close button ── */
.mobile-overlay-close {
  position: absolute;
  top: 10px;
  right: 20px;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  cursor: pointer;
  color: #1A1A1A;
  z-index: 10;
  border-radius: 50%;
  transition: background 0.2s ease;
}

.mobile-overlay-close:hover {
  background: rgba(0, 0, 0, 0.05);
}

/* ── Fullscreen overlay ── */
.mobile-overlay {
  position: fixed;
  inset: 0;
  z-index: 1050;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.35s ease, visibility 0.35s ease;
}

.mobile-overlay.is-open {
  opacity: 1;
  visibility: visible;
}

/* ── Nav links ── */
.mobile-overlay-nav {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.mobile-overlay-nav a {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 22px;
  font-weight: 600;
  color: #1A1A1A;
  padding: 14px 0;
  text-decoration: none;
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.3s ease, transform 0.3s ease, color 0.15s ease;
}

.mobile-overlay.is-open .mobile-overlay-nav a {
  opacity: 1;
  transform: translateY(0);
}

.mobile-overlay.is-open .mobile-overlay-nav a:nth-child(1) { transition-delay: 0.05s; }
.mobile-overlay.is-open .mobile-overlay-nav a:nth-child(2) { transition-delay: 0.10s; }
.mobile-overlay.is-open .mobile-overlay-nav a:nth-child(3) { transition-delay: 0.15s; }
.mobile-overlay.is-open .mobile-overlay-nav a:nth-child(4) { transition-delay: 0.20s; }
.mobile-overlay.is-open .mobile-overlay-nav a:nth-child(5) { transition-delay: 0.25s; }

.mobile-overlay-nav a:hover {
  color: #D4870E;
}

/* ── Download CTA button ── */
.mobile-overlay-download {
  margin-top: 16px;
  font-size: 16px !important;
  background: #D4870E;
  color: #fff !important;
  padding: 12px 40px !important;
  border-radius: 8px;
}

.mobile-overlay-download:hover {
  background: #B87308;
  color: #fff !important;
}
</style>

<script is:inline>
(function () {
  var btn = document.getElementById('menuToggle');
  var overlay = document.getElementById('mobileOverlay');
  var closeBtn = document.getElementById('mobileOverlayClose');
  if (!btn || !overlay) return;

  function closeMenu() {
    btn.classList.remove('is-open');
    overlay.classList.remove('is-open');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', function () {
    var open = btn.classList.toggle('is-open');
    overlay.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', open);
    document.body.style.overflow = open ? 'hidden' : '';
  });

  if (closeBtn) {
    closeBtn.addEventListener('click', closeMenu);
  }

  overlay.addEventListener('click', function (e) {
    if (e.target === overlay || e.target.tagName === 'A') {
      closeMenu();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
      closeMenu();
    }
  });
})();
</script>
